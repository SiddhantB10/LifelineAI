{
  "functions": {
    "source": "backend/functions"
  },
  "hosting": [
    {
      "target": "web",
      "site": "lifelineai-100",
      "public": "frontend/dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ]
}
